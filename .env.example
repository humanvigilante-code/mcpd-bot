# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to a public repo.

# From developer.x.com — your app's OAuth 1.0a credentials (needs "Read and Write" permission)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Optional but recommended: free Socrata app token, raises your rate limit
# on data.montgomerycountymd.gov. Get one at https://data.montgomerycountymd.gov/profile/app_tokens
SOCRATA_APP_TOKEN=
